{
  "permissions": {
    "allow": [
      "Bash(grep -r \"VITE_SUPABASE_URL\" .env*)",
      "Bash(tasklist)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://127.0.0.1:54321/functions/v1/users)",
      "Bash(xargs ls:*)",
      "Bash(node -e \"const lucide = require\\('lucide-react'\\); const icon = lucide.icons['Phone']; console.log\\('Type:', typeof icon\\); console.log\\('Keys:', Object.keys\\(icon\\)\\)\")",
      "Bash(git add:*)",
      "Bash(git commit -m ':*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-file.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
