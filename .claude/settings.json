{
  "permissions": {
    "allow": [
      "Bash(grep -r \"VITE_SUPABASE_URL\" .env*)",
      "Bash(tasklist)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://127.0.0.1:54321/functions/v1/users)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-file.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
